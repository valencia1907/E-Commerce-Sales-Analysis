<row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="Create Tables for Database" filename="C:/Users/valen/OneDrive/Documents/Job Application/Portfolio/Project E-Commerce Sales &amp; Customer Analysis.sql">-- Reference to file &quot;C:/Users/valen/OneDrive/Documents/Job Application/Portfolio/Project E-Commerce Sales &amp; Customer Analysis.sql&quot; (not supported by this version) --</sql><sql name="Insert Data">--insert inro customers table---
INSERT INTO Customers (customer_id, name, email, city, state) VALUES
(1, 'Alice Green', 'alice@gmail.com', 'Miami', 'FL'),
(2, 'Bob Smith', 'bob@email.com', 'Dallas', 'TX'),
(3, 'Charlie Lee', 'charlie@email.com', 'Austin', 'TX'),
(4, 'Dana White', 'dana@email.com', 'Orlando', 'FL'),
(5, 'Ethan Brown', 'ethan@email.com', 'Seattle', 'WA');

---insert into products table----
INSERT INTO Products (product_id, product_name, category, price) VALUES
(101, 'Laptop', 'Electronics', 900),
(102, 'Headphones', 'Electronics', 120),
(103, 'Desk Chair', 'Furniture', 200),
(104, 'Coffee Table', 'Furniture', 150),
(105, 'Water Bottle', 'Drinkware', 25);

---insert into orders table----
INSERT INTO Orders (order_id, customer_id, product_id, quantity, order_date) VALUES
(1001, 1, 101, 1, '2023-01-10'),
(1002, 1, 105, 3, '2023-01-15'),
(1003, 2, 102, 2, '2023-02-01'),
(1004, 3, 103, 1, '2023-02-05'),
(1005, 4, 104, 2, '2023-02-07'),
(1006, 5, 105, 5, '2023-02-10'),
(1007, 3, 101, 1, '2023-03-01');</sql><sql name="Analysis Queries*">---Total Spend per Customer as total spent---
SELECT c.name, sum(p.price * o.quantity) AS total_spent
FROM customers c
JOIN Orders o ON c.customer_id = o.customer_id
JOIN Products p ON o.product_id = p.product_id
GROUP BY c.name
ORDER BY total_spent DESC;

---Top Selling Products as total sold---
SELECT p.product_name, SUM(o.quantity) AS total_sold
FROM Orders o
JOIN Products p ON o.product_id = p.product_id
GROUP BY p.product_name
ORDER BY total_sold DESC;

---Sales by State as total sales---
SELECT c.state, SUM(p.price * o.quantity) AS total_sales
FROM Customers c
JOIN Orders o ON c.customer_id = o.customer_id
JOIN Products p ON o.product_id = p.product_id
GROUP BY c.state
ORDER BY total_sales DESC;

---Customers who havent ordered anything---
SELECT c.name, c.city, c.state
FROM Customers c
LEFT JOIN Orders o ON c.customer_id = o.customer_id
WHERE o.order_id IS NULL;

---monthly sales trend---
SELECT strftime('%Y-%m', o.order_date) AS month,
       SUM(p.price * o.quantity) AS revenue
FROM Orders o
JOIN Products p ON o.product_id = p.product_id
GROUP BY strftime('%Y-%m', o.order_date)
ORDER BY month;
</sql><current_tab id="2"/></tab_sql></sqlb_project>
